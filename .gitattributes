# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must use LF line endings
*.sh text eol=lf
.husky/** text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.mdc text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Source files
*.rs text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.dll binary
*.exe binary
*.pdb binary
