{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "itunes-mtp",
  "version": "0.1.0",
  "identifier": "tech.quinnjr.itunes-mtp",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/itunes-mtp/browser"
  },
  "app": {
    "windows": [
      {
        "title": "iTunes MTP",
        "width": 1280,
        "height": 1024
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
